%% Supplier Portal — System Architecture (5-Layer Stack)

flowchart TB
    subgraph CLIENTS["🖥️ PRESENTATION LAYER"]
        direction LR
        C1["Supplier Browser\nReact 18.x + G4 DSL"]
        C2["Manager Browser\nReact 18.x + G4 DSL"]
        C3["Admin Browser\nReact 18.x + G4 DSL"]
    end

    subgraph GATEWAY["🔐 API GATEWAY"]
        direction LR
        GW["Gateway Pipeline\nJWT → Rate Limit → Tenant Context → RBAC"]
    end

    C1 & C2 & C3 -->|"HTTPS / TLS 1.3"| GW

    subgraph SERVICES["⚙️ SERVICE LAYER — Spring Boot 3.x"]
        direction LR

        subgraph ONB["Onboarding"]
            S1["Invitation\n12 APIs"]
            S2["Registration\nForm Config + Draft"]
            S3["Document\nUpload, Scan, S3"]
        end

        subgraph CMP["Compliance"]
            S4["Screening\n7 APIs"]
            S5["Approval Engine\n8 APIs"]
        end

        subgraph TXN["Transactional"]
            S6["PO Service\n10 APIs"]
            S7["Invoice Service\n11 APIs"]
            S8["Master Data\n6 APIs"]
        end

        subgraph XCT["Cross-Cutting"]
            S9["Notification\nEmail + WebSocket"]
            S10["Audit\nImmutable, 2yr"]
            S11["Dashboard\nKPI Aggregation"]
            S12["Admin Config\nForms, Workflows"]
        end
    end

    GW --> ONB & CMP & TXN & XCT

    S1 --> S9
    S2 --> S3
    S5 --> S9
    S8 --> S5

    subgraph INTEGRATION["🔌 INTEGRATION LAYER — Adapters"]
        direction LR
        I1["Keycloak\nOIDC / SSO"]
        I2["Screening\nAddr + TIN + Sanctions"]
        I3["Bank\nValidation"]
        I4["ERP\nSAP / Oracle / NetSuite"]
        I5["S3 Storage\n+ Virus Scan"]
        I6["Vault\nSecrets"]
    end

    S4 --> I2 & I3
    S6 & S7 --> I4

    subgraph RESILIENCE["⚡ FAULT TOLERANCE"]
        direction LR
        FT["Circuit Breaker → Retry Queue → Dead Letter Queue"]
    end

    I1 & I2 & I3 & I4 --> FT

    subgraph EXTERNAL["🏢 EXTERNAL SYSTEMS — HighRadius"]
        direction LR
        E1["Keycloak IAM"]
        E2["Screening APIs"]
        E3["Bank Validation"]
        E4["ERP Systems"]
        E5["G4 Platform"]
    end

    I1 --> E1
    I2 --> E2
    I3 --> E3
    I4 --> E4
    I5 --> E5

    subgraph DATA["💾 DATA LAYER"]
        direction LR
        DB["PostgreSQL\nMulti-Tenant\nRLS per Schema"]
        COMMON["Common Schema\nTemplates, i18n, Workflows"]
        REDIS["Redis\nCache + Job Queue"]
    end

    ONB & CMP & TXN --> DB
    S12 --> COMMON
    S11 & S4 & S9 --> REDIS
    S10 -.->|"Every Action Logged"| DB

    style CLIENTS fill:#e3f2fd,stroke:#1565C0,color:#0d47a1
    style GATEWAY fill:#fce4ec,stroke:#c62828,color:#b71c1c
    style SERVICES fill:#e8f5e9,stroke:#2E7D32,color:#1b5e20
    style INTEGRATION fill:#fff8e1,stroke:#F9A825,color:#e65100
    style DATA fill:#f3e5f5,stroke:#7B1FA2,color:#4a148c
    style EXTERNAL fill:#efebe9,stroke:#4E342E,color:#3e2723
    style RESILIENCE fill:#ffebee,stroke:#d32f2f,color:#b71c1c
